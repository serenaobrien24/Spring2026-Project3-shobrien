@model Spring2026_Project3_shobrien.Models.Actor

@{
    ViewData["Title"] = "Edit Actor";
}
<h1>@ViewData["Title"]</h1>

<h3>Edit actor</h3>

<form asp-action="Edit" method="post" enctype="multipart/form-data">
    <input type="hidden" asp-for="ActorID"/>
    <div class="form-group">
           <label for="Name">Name</label>
           <input type="text" class="form-control" asp-for="Name"/>
    </div>
    <div class="form-group">
           <label for="Gender">Gender</label>
           <input type="text" class="form-control" asp-for="Gender"/>
    </div>
    <div class="form-group">
           <label for="Age">Age</label>
           <input type="number" class="form-control" asp-for="Age"/>
    </div>
    <div class="form-group">
           <label for="IMDBLink">IMDBLink</label>
           <input type="text" class="form-control" asp-for="IMDBLink"/>
    </div>
    <div class="form-group">
           <label for="Photo">Photo</label>
           <input type="file" id = "Photo" name="Photo" accept="image/*" class="form-control"/>
    </div>
    <button type="submit" class="btn btn-primary">Save Changes</button>
    <a class="btn btn-secondary" href="@Url.Action("Index")">Cancel</a>
</form>