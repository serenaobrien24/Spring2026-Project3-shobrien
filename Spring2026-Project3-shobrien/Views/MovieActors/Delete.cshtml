@model Spring2026_Project3_shobrien.Models.MovieActorViewModel

@{
    ViewData["Title"] = "Delete Relationship";
}
<h1>@ViewData["Title"]</h1>

<h3>Are you sure you want to delete this?</h3>

<div>
    <p><strong>Movie:</strong> @Model.MovieTitle</p>
    <p><strong>Actor:</strong> @Model.ActorName</p>
</div>

<form asp-action="Delete" method="post">
    <input type="hidden" name="movieID" value="@Model.MovieID" />
    <input type="hidden" name="actorID" value="@Model.ActorID" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a class="btn btn-secondary" asp-action="Index">Cancel</a>
</form>
