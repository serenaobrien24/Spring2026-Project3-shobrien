@model Spring2026_Project3_shobrien.Models.MovieActorViewModel

@{
    ViewData["Title"] = "Edit Relationship";
}
<h1>@ViewData["Title"]</h1>

<h3>Edit movie-actor relationship</h3>

<form asp-action="Edit" method="post">
    <input type="hidden" name="oldMovieId" value="@Model.MovieID" />
    <input type="hidden" name="oldActorId" value="@Model.ActorID" />

    <div class="form-group">
        <label>Actor</label>
        <select asp-for="ActorID" class="form-control"
                asp-items="@(new SelectList(ViewBag.Actors, "ActorID", "Name", Model.ActorID))">
            <option value="">-- Select Actor --</option>
        </select>
    </div>

    <div class="form-group">
        <label>Movie</label>
        <select asp-for="MovieID" class="form-control"
                asp-items="@(new SelectList(ViewBag.Movies, "MovieID", "Title", Model.MovieID))">
            <option value="">-- Select Movie --</option>
        </select>
    </div>

    <button type="submit" class="btn btn-primary mt-2">Save Changes</button>
    <a class="btn btn-secondary" href="@Url.Action("Index")">Cancel</a>
</form>


