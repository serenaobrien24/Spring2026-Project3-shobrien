@model Spring2026_Project3_shobrien.Models.MovieDetailsViewModel


<h1>@Model.Movie.Title</h1>

<p><strong>Genre:</strong> @Model.Movie.Genre</p>
<p><strong>Release Year:</strong> @Model.Movie.ReleaseYear</p>
<p><strong>IMDB:</strong> <a href="@Model.Movie.IMDBLink" target="_blank">Link</a></p>

@if (Model.Movie.Poster != null && Model.Movie.Poster.Length > 0)
{
    var base64 = Convert.ToBase64String(Model.Movie.Poster);
    var imgSrc = $"data:image/jpeg;base64,{base64}";
    <img src="@imgSrc" width="300" />
}

<a class="btn btn-warning" href="@Url.Action("Edit", new { id = Model.Movie.MovieID })">Edit</a>
<a class="btn btn-danger" href="@Url.Action("Delete", new { id = Model.Movie.MovieID })">Delete</a>
<a class="btn btn-secondary" href="@Url.Action("Index")">Back to List</a>

<h3>Reviews</h3>

<table id="reviewsTable" class="table" data-table>
    <thead>
        <tr>
            <th>#</th>
            <th>Review</th>
        </tr>
    </thead>
    <tbody>
        @for (int i=0; i < Model.Reviews.Count; i++)
        {
            <tr>
                <td>@(i+1)</td>
                <td>@Model.Reviews[i]</td>
            </tr>
        }
    </tbody>

</table>
