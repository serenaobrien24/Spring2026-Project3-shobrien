@model Spring2026_Project3_shobrien.Models.MovieDetailsViewModel

<div class="details-header">
    <h1>@Model.Movie.Title</h1>

    @if (Model.Movie.Poster != null && Model.Movie.Poster.Length > 0)
    {
        var base64 = Convert.ToBase64String(Model.Movie.Poster);
        var imgSrc = $"data:image/jpeg;base64,{base64}";
        <img src="@imgSrc" width="300" class="details-image"/>
    }

    <div class="details-info">
        <p><strong>Genre:</strong> @Model.Movie.Genre</p>
        <p><strong>Release Year:</strong> @Model.Movie.ReleaseYear</p>
        <p><strong>IMDB:</strong> <a href="@Model.Movie.IMDBLink" target="_blank">Link</a></p>
    </div>

    <div class="buttons-menu">
        <a class="btn btn-warning" href="@Url.Action("Edit", new { id = Model.Movie.MovieID })">Edit</a>
        <a class="btn btn-danger" href="@Url.Action("Delete", new { id = Model.Movie.MovieID })">Delete</a>
        <a class="btn btn-secondary" href="@Url.Action("Index")">Back to List</a>
    </div>
</div>

<h3>Reviews</h3>
<h5>Average Sentiment: @Model.AverageSentiment.ToString("F2")</h5>
<table id="reviewsTable" class="table" data-table>
    <thead>
        <tr>
            <th>#</th>
            <th>Review</th>
            <th>Sentiment</th>
        </tr>
    </thead>
    <tbody>
        @for (int i=0; i < Model.Reviews.Count; i++)
        {
            <tr>
                <td>@(i+1)</td>
                <td>@Model.Reviews[i]</td>
                <td>@Model.Sentiments[i].ToString("F2")</td>
            </tr>
        }
    </tbody>

</table>

<h3>Actors Featured in <strong>@Model.Movie.Title</strong></h3>
<table id="moviesTable" class="table" data-table>
    <thead>
        <tr>
            <th>Name</th>
            <th>Gender</th>
            <th>Age</th>
            <th>IMDB</th>
            <th>Photo</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var actor in Model.Actors)
        {
            <tr>
                <td>@actor.Name</td>
                <td>@actor.Gender</td>
                <td>@actor.Age</td>
                <td><a href="@actor.IMDBLink" target="_blank">IMDB</a></td>
                <td>
                    @if (actor.Photo != null && actor.Photo.Length > 0)
                    {
                        var base64 = Convert.ToBase64String(actor.Photo);
                        var imgSrc = $"data:image/jpeg;base64,{base64}";
                        <img src="@imgSrc" width="100" />
                    }
                </td>
                <td>
                    <a class="btn btn-info btn-sm" href="@Url.Action("Details", new { id = actor.ActorID })">Details</a>
                    <a class="btn btn-warning btn-sm" href="@Url.Action("Edit", new { id = actor.ActorID })">Edit</a>
                    <a class="btn btn-danger btn-sm" href="@Url.Action("Delete", new { id = actor.ActorID })">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
